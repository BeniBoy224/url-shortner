# App
NEXT_PUBLIC_BASE_URL="https://yourdomain.com"
AUTH_SECRET=""  # generate with: openssl rand -base64 32

# Database URL — point to your external PostgreSQL instance
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/link_to"